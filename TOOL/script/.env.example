# QNAIGC ASR
QNAIGC_API_KEY=<API_KEY>
QNAIGC_ASR_URL=https://api.qnaigc.com/v1/voice/asr
QNAIGC_ASR_MODEL=asr

# Option A: if files in TOOL/audios are already reachable at:
#   ${QNAIGC_AUDIO_BASE_URL}/${filename}
# set this and run without --upload.
QNAIGC_AUDIO_BASE_URL=

# Option B: upload local TOOL/audios files to Qiniu Kodo, then call ASR with
# the uploaded URL. Use this when QNAIGC_AUDIO_BASE_URL is empty.
QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=
QINIU_BUCKET=
# Use http:// for Qiniu temporary/test domains unless you have configured HTTPS
# for a custom CDN domain.
QINIU_DOMAIN=
QINIU_KEY_PREFIX=asr-audios
QINIU_PRIVATE_BUCKET=false
QINIU_UPLOAD_TOKEN_EXPIRES=3600
